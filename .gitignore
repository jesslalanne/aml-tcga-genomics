# =============================================================================
# AML TCGA Genomics — .gitignore
# Raw data files are NOT committed to this repo.
# Download instructions: see data/README.md
# =============================================================================

# ── Raw TCGA data files ───────────────────────────────────────────────────────
data/*.txt
data/*.seg
data/*.tsv

# Keep these small metadata files in the repo
!data/meta_study.txt
!data/README.md

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

